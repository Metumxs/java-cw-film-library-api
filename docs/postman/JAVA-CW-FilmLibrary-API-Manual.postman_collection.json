    {
      "name": "Auth | Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();\r",
              "\r",
              "var token = jsonData.accessToken; \r",
              "\r",
              "if (token)\r",
              "{\r",
              "    pm.collectionVariables.set(\"Access Token\", token);\r",
              "    console.log(\"Token has been saved to collection variables!\");\r",
              "} \r",
              "else\r",
              "{\r",
              "    console.error(\"Token not found in response! Check the field name (e.g., 'token' or 'accessToken')\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
